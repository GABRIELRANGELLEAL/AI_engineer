# Database
DATABASE_URL=postgresql://app:app@localhost:5432/analytics

# JWT authentication
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# Symmetric encryption for DB credentials (generate with Fernet.generate_key())
FERNET_KEY=

# Google OAuth2 (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# App URLs
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Password recovery
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Refresh token cookie
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Email (mock logs to console when EMAIL_MOCK=true)
EMAIL_MOCK=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localhost

# Data connection test timeout (seconds)
DB_CONNECTION_TEST_TIMEOUT_SECONDS=10

# Existing agent keys
ANTHROPIC_API_KEY=
